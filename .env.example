# Copy to .env and fill only the backend you are running. Never commit .env.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/
MONGODB_DATABASE=vector_rag
MONGODB_COLLECTION=chunks
MONGODB_VECTOR_INDEX=vector_index
MONGODB_TEXT_INDEX=text_index

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vector_rag_chunks

# Optional generation provider. Retrieval benchmarks need no paid API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

